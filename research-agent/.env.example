# ============================================================
#  AI-Driven Autonomous Research Agent — environment variables
# ============================================================
#
# Copy this file to .env and fill in the values you need.
# The agent also accepts all of these as CLI flags — CLI flags
# always take precedence over environment variables.
#
# Usage:
#   cp .env.example .env
#   # edit .env, then:
#   python -m src.main --topic "Your Topic" --duration 1h
#
# Lines starting with # are comments and are ignored.
# ============================================================


# ── Search API ───────────────────────────────────────────────
# Required. Get a free key at https://app.tavily.com
# CLI equivalent: --tavily-key
TAVILY_API_KEY=tvly-YOUR-API-KEY-HERE


# ── LLM Provider ─────────────────────────────────────────────
# Model name for the selected LLM provider.
# CLI equivalent: --model
# Default: qwen2.5:7b
#RESEARCH_MODEL=qwen2.5:7b

# Which backend to use: ollama | openai | siliconflow
# CLI equivalent: --llm-provider
# Default: ollama
#RESEARCH_LLM_PROVIDER=ollama

# Base URL for the LLM endpoint.
# Ollama default: http://localhost:11434
# SiliconFlow:    https://api.siliconflow.cn/v1
# CLI equivalent: --llm-url
#RESEARCH_LLM_URL=http://localhost:11434

# API key for online OpenAI-compatible providers (openai, siliconflow, etc.).
# Not required for local Ollama.
# CLI equivalent: --llm-api-key
#RESEARCH_LLM_API_KEY=sk-YOUR-API-KEY-HERE

# Convenience alias used by some SiliconFlow examples.
# Has lower priority than RESEARCH_LLM_API_KEY.
#SILICONFLOW_API_KEY=sk-YOUR-SILICONFLOW-KEY-HERE


# ── Prompt Templates ─────────────────────────────────────────
# Directory containing .md prompt template overrides.
# Missing files fall back to the bundled prompts/ directory.
# CLI equivalent: --prompt-dir
#RESEARCH_PROMPT_DIR=/path/to/my-prompts


# ── Budget Controls ──────────────────────────────────────────
# Maximum Tavily search API calls per session.
# CLI equivalent: --max-queries
#RESEARCH_MAX_QUERIES=200

# Maximum topic-graph nodes to create per session.
# CLI equivalent: --max-nodes
#RESEARCH_MAX_NODES=50

# Maximum Tavily credits to spend per session.
# CLI equivalent: --max-credits-spend
#RESEARCH_MAX_CREDITS=100


# ── Scraping Controls ────────────────────────────────────────
# Enable advisory robots.txt checks before scraping (default: off).
# Set to "true" to opt in.
# CLI equivalent: --respect-robots
#RESEARCH_RESPECT_ROBOTS=false
